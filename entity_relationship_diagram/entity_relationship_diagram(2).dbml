// ============================================
// Central Dimension Table
// ============================================

Table dim_dates {
  date_id integer [pk, increment]
  full_date date [unique] // 2026-02-06, 2027-03-09, 2028-04-10 
  year year // 2026, 2027, 2028
  quarter char(2) // Q1, Q2, Q3
  month integer // 2, 3, 4
  month_name varchar(20) // February, March, April
  week_number integer // 16, 17, 18
  day_name varchar(20) // Monday, Tuesday, Wednesday
  is_weekend boolean // FALSE, FALSE, FALSE
  is_holiday boolean // FALSE, FALSE, FALSE
  created_at timestamp [default: `now()`] // 2026-02-06 15:58:00, 2026-02-06 17:58:00, 2026-02-06 19:58:00
}

Table dim_times {
  time_id integer [pk, increment]
  time time // 08:38:38, 12:38:38, 16:38:38
  time_period char(2) // AM, PM
}





// ============================================
// Indicator: Reduction percentage in inflation rates through price monitoring and direct selling of basic commodities
// Lead Department: OPPDC
// Frequency: Annually
// Data Source: Provincial Online Price Monitoring System

// ============================================

Table dim_local_government_units {
  lgu_id integer [pk, increment]
  district_name varchar(50) // District I, District II, District III
  lgu_name varchar(150) // Abucay, Balanga, Orani
  created_at timestamp [default: `now()`] // 2026-02-06 15:58:00, 2026-02-06 17:58:00, 2026-02-06 19:58:00
}

Table dim_agricultural_products {
  product_id integer [pk, increment]
  commodity_type varchar(255) // IMPORTED COMMERCIAL RICE, FISH (per kg), HIGHLAND VEGETABLES (per kg)
  product_name varchar(255) // Special (Blue tag), Galunggong (Local), Pechay (Baguio)
  created_at timestamp [default: `now()`] // 2026-02-06 16:13:13, // 2026-02-06 20:13:13, // 2026-02-07 16:13:13
}

Table dim_price_comparison_periods {
  comparison_period_id integer [pk, increment]
  comparison_period varchar(20) // CURRENT, PREVIOUS, OTHER
  created_at timestamp [default: `now()`] // 2026-02-06 16:13:13, // 2026-02-06 20:13:13, // 2026-02-07 16:13:13
}

Table fact_prices [note: 'Reduction percentage in inflation rates through price monitoring and direct selling of basic commodities (OPPDC)'] {
  price_id integer [pk, increment]
  observation_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  lgu_id integer [not null, ref: > dim_local_government_units.lgu_id]
  product_id integer [not null, ref: > dim_agricultural_products.product_id]
  comparison_period_id integer [not null, ref: > dim_price_comparison_periods.comparison_period_id]
  average_price decimal(10, 2) // 216.00, 172.50, 216
  prevailing_price decimal(10, 2) // 225.00, 170.00, 220
  created_at timestamp [default: `now()`] // 2026-02-06 16:13:13, // 2026-02-06 20:13:13, // 2026-02-07 16:13:13 
  updated_at timestamp // 2026-02-06 16:13:13, // 2026-02-06 20:13:13, // 2026-02-07 16:13:13

  indexes {
    (observation_date_id, lgu_id, product_id) [name: 'idx_price_lookup']
    (coverage_start_date_id, coverage_end_date_id) [name: 'idx_coverage_period']
  }
}



// ============================================
// Indicator: Increase percentage in barangays with completed Barangay Master Development Plans
// Lead Department: OPPDC
// Frequency: Annually
// Data Source: Submitted reports of District Offices about the number of barangays who completed their master development plan per municipalities divided by the number of barangays per municipalities
// ============================================

Table dim_municipalities {
  municipality_id integer [pk, increment]
  district_name varchar(50) // District I, District II, District III
  municipality_name varchar(100) // Hermosa, City of Balanga, Bagac
  created_at timestamp [default: `now()`] // 2026-02-06 16:18:18, 2026-02-06 17:18:18, 2026-02-06 20:18:18
}

Table fact_barangay_development_plans [note: 'Increase percentage in barangays with completed Barangay Master Development Plans (OPPDC)']{
  plan_id integer2 [pk, increment]
  observation_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  municipality_id integer [not null, ref: > dim_municipalities.municipality_id]
  barangays_not_started integer // 10, 0, 6
  barangays_in_progress intege // 3, 12, 2
  barangays_with_completed_bdp integer // 10, 13, 6
  total_barangays integer // 23, 25, 14
  completion_percentage decimal(5, 2) // 43.48, 52, 42.86
  created_at timestamp [default: `now()`] // 2026-02-06 16:18:18, 2026-02-06 17:18:18, 2026-02-06 20:18:18
  updated_at timestamp // 2026-02-06 16:18:18, 2026-02-06 17:18:18, 2026-02-06 20:18:18

  indexes {
    (municipality_id, observation_date_id) [name: 'idx_plan_lookup']
    (coverage_start_date_id, coverage_end_date_id) [name: 'idx_coverage_lookup']
  }
}





// ============================================
// Indicator: Increase percentage in citizen concerns addressed via the 8888 hotline
// Lead Department: Legal & PHRMO
// Frequency: Annually
// Data Source: Submitted Performance Report transmitted by the 8888 Citizen's Complaint Center to the PGO
// ============================================

Table dim_ticket_names {
  ticket_name_id integer [pk, increment]
  ticket_classification_name varchar(255) // 2025 Graft and Corruption, 2025 Integrity and Conduct, 2025 Frontline Service Procedures
  ticket_name varchar(255) // 2025 Against Government Official, 2025 - Integrity and Conduct - Official, 2025 - Discourtesy
  year_applicable year // 2025/2026, 2025, 2024
  created_at timestamp [default: `now()`] // 2026-02-07 19:23:59, 2026-02-07 21:23:59, 2026-02-07 12:23:59
}

Table fact_performance_reports [note: 'Increase percentage in citizen concerns addressed via the 8888 hotline (Legal & PHRMO)']{
  report_id integer [pk, increment]
  report_date_id integer [not null, ref: > dim_dates.date_id]
  reported_time_id integer [not null, ref: > dim_times.time_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  ticket_name_id integer [not null, ref: > dim_ticket_names.ticket_name_id]
  tickets_resolved_count integer // 23, 24, 25
  tickets_in_progress_count integer // 0, 1, 2
  tickets_pending_count integer // 3, 2, 1
  total_tickets integer // 26, 26, 28
  resolution_rate decimal(5, 2) // 88.46, 92.30, 88.29
  created_at timestamp [default: `now()`] // 2026-02-07 19:23:59, 2026-02-07 21:23:59, 2026-02-07 12:23:59
  updated_at timestamp // 2026-02-07 19:23:59, 2026-02-07 21:23:59, 2026-02-07 12:23:59

  indexes {
    (report_date_id, ticket_name_id) [name: 'idx_report_lookup']
    (coverage_start_date_id, coverage_end_date_id) [name: 'idx_coverage_lookup']
  }
}



// ============================================
// Indicator: Improvement percentage in government employee service quality
// Lead Department: PHRMO
// Frequency: Annually
// Data Source: Information Table for the Outreach Program provided by the PHRMO
// ============================================

Table dim_locations {
  location_id integer [pk, increment]
  location varchar(75) // Limay, Mariveles, Bahay Puso
  created_at timestamp [default: `now()`] // 2026-02-09 09:27:27, 2026-02-09 09:37:27, 2026-02-09 09:57:27
}

Table dim_implementing_offices {
  implementing_office_id integer [pk, increment]
  office_code varchar(50) // PIO, OPPDC, BPPIC
  office_name varchar(150) // Provincial Information Office, Office of the Provincial Planning and Development Coordinator, Bataan Public-Private Partnership and Investment Center
  created_at timestamp [default: `now()`] // 2026-02-09 09:27:27, 2026-02-09 09:37:27, 2026-02-09 09:57:27
}

Table dim_program_heads {
  program_head_id integer [pk, increment]
  program_head varchar(150) // Ms. Angel O.L Lara, Ar. Mc Jefferson M. Valerio, Mr. Abul Khayr Amalon M. Alonto II
  created_at timestamp [default: `now()`] // 2026-02-09 09:27:27, 2026-02-09 09:37:27, 2026-02-09 09:57:27
}

Table dim_beneficiaries {
  beneficiary_id integer [pk, increment]
  beneficiary varchar(255) // Aeta Magbukun, Children of SOS Orphanage, Children of King's Garden Orphanage
  created_at timestamp [default: `now()`] // 2026-02-09 09:27:27, 2026-02-09 09:37:27, 2026-02-09 09:57:27
}

Table fact_participation_rates [note: 'Improvement percentage in government employee service quality (PHRMO)']{
  participation_rate_id integer [pk, increment]
  report_date_id integer [not null, ref: > dim_dates.date_id]
  program_start_date_id integer [not null, ref: > dim_dates.date_id]
  program_end_date_id integer [not null, ref: > dim_dates.date_id]
  location_id integer [not null, ref: > dim_locations.location_id]
  implementing_office_id integer [not null, ref: > dim_implementing_offices.implementing_office_id]
  program_head_id integer [not null, ref: > dim_program_heads.program_head_id]
  beneficiary_id integer [not null, ref: > dim_beneficiaries.beneficiary_id]
  number_of_participated_employees bigint // 54, 35, 38
  number_of_eligible_employees bigint // 188, 143, 146
  participation_rate decimal(5, 2) // 28.72, 24.48, 26.02
  created_at timestamp [default: `now()`] // 2026-02-09 09:27:27, 2026-02-09 09:37:27, 2026-02-09 09:57:27
  updated_at timestamp // 2026-02-09 09:27:27, 2026-02-09 09:37:27, 2026-02-09 09:57:27

  indexes {
    (report_date_id) [name: 'idx_report_lookup']
    (program_start_date_id, program_end_date_id) [name: 'idx_coverage_lookup']
  }
}





// ============================================
// Indicator: Reduction percentage in crime rates through collaboration with law enforcement 
// Lead Department: MBDA
// Frequency: Annually
// Data Source: Submitted crime reports of PNP/MBDA Daily
// ============================================

Table dim_police_stations {
  police_station_id integer [pk, increment]
  municipality_name varchar(150) // City of Balanga, Abucay, Dinalupihan
  barangay_name varchar(150) // Malabia, Laon, San Ramon
  police_station varchar(150) // Balanga City Police Station, Abucay Municipal Police Station, Dinalupihan Municipal Police Station
  created_at timestamp [default: `now()`] // 2026-02-09 13:35:35, 2026-02-10 13:35:35, 2026-02-11 13:35:35
}

Table fact_crime_reports [note: 'Reduction percentage in crime rates through collaboration with law enforcement (MBDA)'] {
  crime_report_id integer [pk, increment]
  reported_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  police_station_id integer [not null, ref: > dim_police_stations.police_station_id]
  total_no_of_index_crime_reported bigint // 1068, 922, 1211 
  total_no_of_crime_reported bigint // 345, 822, 1000
  index_crime_rate decimal (5, 2) // 58.23, 22.13, 09.82
  created_at timestamp [default: `now()`] // 2026-02-09 13:35:35, 2026-02-10 13:35:35, 2026-02-11 13:35:35
  updated_at timestamp // 2026-02-09 13:35:35, 2026-02-10 13:35:35, 2026-02-11 13:35:35

  indexes {
    (reported_date_id, police_station_id) [name: 'idx_report_lookup']
    (coverage_start_date_id, coverage_end_date_id) [name: 'idx_coverage_lookup']
    (police_station_id) [name: 'idx_station_lookup']
  }
}



// ============================================
// Indicator: Reduction of percentage on accidents (place on occurence)
// Lead Department: MBDA, PNP, and PDRRMO
// Frequency: Monthly
// Data Source: Accident Report Submitted by the MBDA, PNP, and PDRRMO
// ============================================

Table dim_barangay_locations {
  barangay_location_id integer [pk, increment]
  district_name varchar(50) // District I, District II, District III,
  municipality_name varchar(100) // Abucay, City of Balanga, Dinalupihan
  barangay_name varchar(150) // Calaylayan, San Jose, Poblacion
  created_at timestamp [default: 'now()'] // 2026-02-10 13:19:19, 2026-02-11 13:19:19, 2026-02-12 13:19:19
}

Table dim_latlong_locations {
  latlong_location_id integer [pk, increment]
  location text // Intersection of ..., Near barangay hall of San Jose, Dinalupihan Memorial Park
  latitude decimal(9, 6) // 40.758896, 51.508039, 35.661777
  longitude decimal(10, 6) // -73.985130, -0.128020, 139.700478
  created_at timestamp [default: 'now()'] // 2026-02-10 13:19:19, 2026-02-11 13:19:19, 2026-02-12 13:19:19
}

Table dim_accident_types {
  accident_type_id integer [pk, increment]
  accident_type varchar(150) // Vehicular Accidents, Fire Incidents, Others
  created_at timestamp [default: 'now()'] // 2026-02-10 13:19:19, 2026-02-11 13:19:19, 2026-02-12 13:19:19
}

Table fact_accident_reports [note: 'Reduction of percentage on accidents (place on occurence) (MBDA, PNP, and PDRRMO)'] {
  accident_report_id integer [pk, increment]
  reported_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  barangay_location_id integer [ref: > dim_barangay_locations.barangay_location_id]
  latlong_location_id integer [ref: > dim_latlong_locations.latlong_location_id]
  accident_type_id integer [not null, ref: > dim_accident_types.accident_type_id]
  accident_count bigint // 1477, 2122, 902
  created_at timestamp [default: 'now()'] // 2026-02-10 13:19:19, 2026-02-11 13:19:19, 2026-02-12 13:19:19
  updated_at timestamp // 2026-02-10 13:19:19, 2026-02-11 13:19:19, 2026-02-12 13:19:19

  indexes {
    (reported_date_id, accident_type_id) [name: 'idx_report_lookup']
    (coverage_start_date_id, coverage_end_date_id) [name: 'idx_coverage_lookup']
    (accident_type_id) [name: 'idx_accident_type_lookup']
  }
}



// ============================================
// Indicator: Reduction percentage of injury among affected population during calamity
// Lead Department: MBDA and PDRRMO
// Frequency: During Situational Report (Can be Daily, Weekly, Monthly, Quarterly, and Annually)
// Data Source: Situational Report Submitted by MBDA and/or PDRRMO
// ============================================

Table dim_calamities {
  calamity_id integer [pk, increment]
  calamity_name varchar(255) // Typhoon Yolanda, Earthquake Magnitude 8.2, Robinson Fire
  calamity_type varchar(255) // Meteorological, Geological, Technological
  created_at timestamp [default: 'now()'] // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06
}

enum population_type {
  Province
  District
  Municipality
  Barangay
}

Table dim_affected_populations {
  affected_population_id integer [pk, increment]
  population_type population_type // Province, District, Municipality
  population_name varchar(255) // Bataan, District II, City of Balanga
  created_at timestamp [default: 'now()'] // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06
}

Table fact_situational_reports [note: 'Reduction percentage of injury and casualties among affected population during calamity (MBDA and PDRRMO)'] {
  situational_report_id integer []
  reported_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  affected_population_id integer [not null, ref: > dim_affected_populations.affected_population_id]
  calamity_id integer [ref: > dim_calamities.calamity_id]
  total_no_of_reported_fatality bigint // 233, 123, 321
  total_no_of_reported_injuries bigint // 435, 1288, 345
  total_no_of_reported_missing_persons bigint // 28, 1, 3
  total_no_of_casualties bigint // 696, 1412, 669
  created_at timestamp [default: 'now()'] // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06
  updated_at timestamp // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06

  indexes {
    (reported_date_id, affected_population_id) [name: 'idx_report_lookup']
    (affected_population_id) [name: 'idx_affected_population_lookup']
    (coverage_start_date_id, coverage_end_date_id) [name: 'idx_coverage_lookup']
  }
}
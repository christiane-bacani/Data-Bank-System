table dim_government_sectors {
  sector_id integer [pk, increment]
  sector varchar(100) // Development Admininstration, Economic, Social
  dimension varchar(100) // Governance, Standard of Living, Health
}

Table dim_dates {
  date_id integer [pk, increment]
  full_date date // 2026-01-04, 2027-01-04, 2028-01-04
  year year // 2026, 2027, 2028
  quarter char(2) // Q1, Q2, Q3
  month varchar(50) // January, February, March
  month_number month // 1, 2, 3
  week_number integer // 2, 3, 4
  weekday varchar(255) // Monday, Tuesday, Wednesday
}



// Indicator: Reduction percentage in inflation rates through price monitoring and direct selling of basic commodities
// Frequency: Annually
// How to verify the data?: Provincial Online Price Monitoring System

Table dim_local_government_units {
  government_unit_id integer [pk, increment]
  local_government_unid varchar(150) // Abucay, Bagac, Balanga
  district varchar(50) // District 1, District 2, District 3
}

Table dim_agricultural_products {
  agricultural_product_id integer [pk, increment]
  commodity_type varchar(255) // IMPORTED COMMERCIAL RICE (per kg), FISH (per kg), SPICES (per kg)
  agriculcultural_product varchar(255) // Premium (Yellow tag), Bangus, Garlic (Native)
}

Table dim_helpers {
  helper_id integer [pk, increment]
  helper varhcar(50) // Other, Previous, Current
}

Table fact_prices {
  price_id integer [pk, increment]
  sector_id integer [ref: > dim_government_sectors.sector_id]
  government_unit_id integer [ref: > dim_local_government_units.government_unit_id]
  agricultural_product_id integer [ref: > dim_agricultural_products.agricultural_product_id]
  observation_date_id integer [ref: > dim_dates.date_id]
  coverage_period_start_date_id integer [ref: > dim_dates.date_id]
  coverage_period_end_date_id integer [ref: > dim_dates.date_id]
  helper_id integer [ref: > dim_helpers.helper_id]
  average_price decimal(8, 2) // 300.00, 63.33, 198.75
  prevailing_price decimal (8, 2) // 300.00, 63.33, 200
}



// Indicator: Increase percentage in barangays with completed Barangay Master Development Plans
// Frequency: Annually 
// How to verify the data?: Submitted annual reports of District Offices to measure the number of barangays who completed their master development plan per municipality divided by the total number of barangays per municipality

Table dim_districts {
  district_id integer [pk]
  district varchar(100) // District 1, District 2, District 3
}

Table dim_municipalities {
  municipality_id integer [pk, increment]
  district_id integer [ref: > dim_districts.district_id]
  municipality varchar(25) // Hermosa, Orani, Samal
}

Table fact_barangay_development_plans {
  plan_id integer [pk, increment]
  sector_id integer [ref: > dim_government_sectors.sector_id]
  municipality_id integer [ref: > dim_municipalities.municipality_id]
  observation_date_id integer [ref: > dim_dates.date_id]
  coverage_start_date_id integer [ref: > dim_dates.date_id]
  coverage_end_date_id integer [ref: > dim_dates.date_id]
  barangays_with_completed_plans bigint // 13, 14, 14
  total_barangays bigint /// 23, 29, 14
}





// Indicator: Increase percentage in citizen concerns addressed via the 8888 hotline
// Frequency: Annually
// How to verify the data?: 

Table ticket_classifications {
  ticket_classification_id integer [pk, increment]
  ticket_classification varchar(255) // 2025 Graft and Corruption, 2025 Integrity and Conduct, 2025 Frontline Service Procedures
}

Table ticket_names {
  ticket_name_id integer [pk, increment]
  ticket_classification_id integer [ref: > ticket_classifications.ticket_classification_id]
}
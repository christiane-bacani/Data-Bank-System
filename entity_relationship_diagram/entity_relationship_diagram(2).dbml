// Frequency: Quarterly
// Data Source: Project Status Reports submitted by organization/departments/offices/agencies to PGO
// ============================================

Table dim_projects {
  project_id integer [pk, increment]
  project_name varchar(255) // Barangay San Jose Learning Hub, Solar Power Plant Installation, Electric Public Transport Fleet
  project_type varchar(255) // Innovation Hub, Renewable Energy, Green Mobility
  description text //  The Barangay Learning Hub is a community-based center that provides free access to computers, internet, and educational resources., Installation of a solar power plant to supply clean electricity to government buildings, with a plan for recycling or repurposing solar panels at the end of their lifecycle., Adopts electric buses for public transportation, including a program for battery recycling and vehicle disposal at end-of-life, reducing emissions and promoting sustainable urban mobility.
  created_at timestamp [default: 'now()'] // 2026-02-18 10:14:14, 2026-02-19 10:14:14, 2026-02-20 10:14:14
}

Table dim_project_heads {
  project_head_id integer [pk, increment]
  project_head_name varchar(255) // John Doe, Jane Doe, Joe Blow
  created_at timestamp [default: 'now()'] // 2026-02-18 08:19:19, 2026-02-19 08:19:19, 2026-02-20 08:19:19
}

enum project_status {
  Proposed
  Approved
  InProgress
  Operational
  UnderMaintenance
  Suspended
  Closed
}

Table dim_project_statuses {
  project_status_id integer [pk, increment]
  project_status project_status // Proposed, In Progress, Operational
  created_at timestamp [default: 'now()'] // 2026-02-18 08:19:19, 2026-02-19 08:19:19, 2026-02-20 08:19:19
}

Table fact_project_status_reports [note: 'Increase percentage in innovation hubs established and Increase percentage in renewable energy projects and green mobility adoption (PGO)'] {
  project_status_report_id integer [pk, increment]
  reported_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]

  created_at timestamp [default: 'now()'] // 2026-02-16 14:41:41, 2026-02-17 14:41:41, 2026-02-18 14:41:41
  updated_at timestamp // 2026-02-16 14:41:41, 2026-02-17 14:41:41, 2026-02-18 14:41:41

  indexes {
    (coverage_start_date_id, coverage_end_date_id, ppa_id) [name: 'idx_report_lookup']
  }
}


}

Table dim_accident_types {
  accident_type_id integer [pk, increment]
  accident_type varchar(150) // Vehicular Accidents, Fire Incidents, Others
  created_at timestamp [default: 'now()'] // 2026-02-10 13:19:19, 2026-02-11 13:19:19, 2026-02-12 13:19:19
}

Table fact_accident_reports [note: 'Reduction of percentage on accidents (place on occurence) (MBDA, PNP, and PDRRMO)'] {

// ============================================
// Indicator: Reduction percentage of injury among affected population during calamity
// Lead Department: MBDA and PDRRMO
// Frequency: During Situational Report (Can be Daily, Weekly, Monthly, Quarterly, and Annually)
// Data Source: Situational Report Submitted by MBDA and/or PDRRMO
// ============================================

Table dim_reporting_agencies {
  reporting_agency_id integer [pk, increment]
  agency_code varchar(150) // MBDA, PDRMMO
  agency_name varchar(255) // Metro Bataan Development Authority, Pronvicial Disaster Risk Reduction and Management Office
  created_at timestamp [default: 'now()'] // 2026-02-16 09:23:23, 2026-02-17 09:23:23, 2026-02-18 09:23:23
}

enum population_type {
  Province
  District
  Municipality
  Barangay
}

Table dim_affected_populations {
  affected_population_id integer [pk, increment]
  population_type population_type // Province, District, Municipality
  population_name varchar(255) // Bataan, District II, City of Balanga
  created_at timestamp [default: 'now()'] // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06
}

Table dim_calamities {
  calamity_id integer [pk, increment]
  calamity_name varchar(255) // Typhoon Yolanda, Earthquake Magnitude 8.2, Robinson Fire
  calamity_type varchar(255) // Meteorological, Geological, Technological
  created_at timestamp [default: 'now()'] // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06
}

Table fact_situational_reports [note: 'Reduction percentage of injury and casualties among affected population during calamity (MBDA and PDRRMO)'] {
  situational_report_id integer []
  reported_date_id integer [not null, ref: > dim_dates.date_id]
  reported_time_id integer [not null, ref: > dim_times.time_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  reporting_agency_id integer [not null, ref: > dim_reporting_agencies.reporting_agency_id]
  affected_population_id integer [not null, ref: > dim_affected_populations.affected_population_id]
  calamity_id integer [ref: > dim_calamities.calamity_id]
  total_no_of_reported_fatality bigint // 233, 123, 321
  total_no_of_reported_injuries bigint // 435, 1288, 345
  total_no_of_reported_missing_persons bigint // 28, 1, 3
  total_no_of_casualties bigint // 696, 1412, 669
  created_at timestamp [default: 'now()'] // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06
  updated_at timestamp // 2026-02-10 14:06:06, 2026-02-11 14:06:06, 2026-02-12 14:06:06

  indexes {
    (coverage_start_date_id, coverage_end_date_id, affected_population_id, calamity_id) [name: 'idx_report_lookup_for_mbda']
    (coverage_start_date_id, coverage_end_date_id, calamity_id) [name: 'idx_report_lookup_for_pdrrmo']
  }
}





// ============================================
// Indicator: Improvement percentage in government service delivery via social media
// Lead Department: PIO
// Frequency: Annually
// Data Source: Reports submitted by the Digital Media Division of PIO for Social Media Analytics
// ============================================

Table dim_social_media_programs {
  social_media_program_id integer [pk, increment]
  program_category varchar(255) // Public Service Announcements, Community Engagement Campaigns, Event Promotion
  program_name text // Kwentuhan Tayo, Bataeño, Bisita Bayan Outreach Program, Official News & Events Calendar
  description text // A weekly public information and engagement program launched on July 4, 2022 and spearheaded by the Provincial Information Office under the Provincial Government of Bataan., A community outreach initiative that brings provincial leaders, local officials, and community stakeholders together to directly engage residents and address social issues at the local level., The provincial government promotes a wide range of official events via its news portal (1Bataan) and social media channels.
  created_at timestamp [default: 'now()']
}

Table dim_social_media_platforms {
  social_media_platform_id integer [pk, increment]
  social_media_name varchar(255) // Facebook, TikTok, Instagram
  created_at timestamp [default: 'now()'] // 2026-02-12 09:53:33, 2026-02-12 11:53:33, 2026-02-12 14:53:33
}

Table fact_engagement_reports [note: 'Improvement percentage in government service delivery via social media (PIO)'] {
  engagement_report_id integer [pk, increment]
  reported_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  social_media_program_id integer [not null, ref: > dim_social_media_programs.social_media_program_id]
  social_media_platform_id integer [not null, ref: > dim_social_media_platforms.social_media_platform_id]
  total_no_of_reach bigint // 15000, 16000, 17000 
  total_no_of_likes bigint // 5099, 9905, 9059
  total_no_of_shares bigint /// 123, 321, 213
  total_no_of_comments bigint // 684, 784, 884
  total_no_of_followers bigint // 13000, 14000, 15000
  created_at timestamp [default: 'now()'] // 2026-02-12 10:18:18, 2026-02-12 11:18:18, 2026-02-12 12:18:18
  updated_at timestamp // 2026-02-12 10:18:18, 2026-02-12 11:18:18, 2026-02-12 12:18:18

  indexes {
    (coverage_start_date_id, coverage_end_date_id, social_media_program_id) [name: 'idx_general_report_lookup']
    (coverage_start_date_id, coverage_end_date_id, social_media_program_id, social_media_platform_id) [name: 'idx_report_lookup']
  }
}





// ============================================
// Indicator: Increase percentage in implementation of digital governance systems
// Lead Department: PITO
// Frequency: Yearly analysis to compare the average increase percentage per year but weekly data collection and comparison
// Data Source: System Proposal Submitted by PITO to PGO containing the API Credentials to use for system status checkings on a random day per week
// ============================================

Table dim_digital_governance_systems {
  digital_governance_system_id integer [pk, increment]
  system_category varchar(255) // Document Management Systems, Human Resource Information Systems, Financial Management Information Systems
  system_category_code varchar(100) // DMS, HRIS, FMIS
  system_platform varchar(50) // Website, Mobile, Desktop
  system_name varchar(255) // Document Management System of OPPCC, HRIS of PHRMO, FMIS of BPPPIC
  created_at timestamp [default: 'now()'] // 2026-02-21 10:57:57, 2026-02-22 10:57:57, 2026-02-23 10:57:57
}

Table dim_api_credentials {
  api_credentials_id integer [pk, increment]
  credential_type_name varchar(255) // OAuth, API Key, Json-Web Token
  endpoint_url text // https://api.gov/hris/status, https://api.gov/fmis/status, https://api.gov/proc/status
  credential_issuer varchar(150) // Name of the credential issuer to track the health status of the specified governance system
  credential_expiration_date date // 2026-02-12, 2026-02-13, 2026-02-14
  created_at timestamp [default: 'now()'] // 2026-02-12 13:20:20, 2026-02-12 14:20:20, 2026-02-12 13:20:20
}

Table dim_system_statuses {
  system_status_id integer [pk, increment]
  system_status varchar(50) // Online, Offline, Degraded, Maintenance, Error
  created_at timestamp [default: 'now()'] // 2026-02-21 10:57:57, 2026-02-22 10:57:57, 2026-02-23 10:57:57
}

Table dim_last_active_users {
  last_active_user_id integer [pk, increment]
  user_last_activity_timestamp timestamp // 2026-02-21 10:57:57, 2026-02-22 10:57:57, 2026-02-23 10:57:57
  user_id varchar(100) // USER001, USER002, USER003
  username varchar(255) // u***r1, u***r2, u***r3
  created_at timestamp [default: 'now()'] // 2026-02-21 10:57:57, 2026-02-22 10:57:57, 2026-02-23 10:57:57
}

Table fact_system_status_checks [note: 'Increase percentage in implementation of digital governance systems (PITO)'] {
  system_status_check_id integer [pk, increment]
  check_date_id integer [not null, ref: > dim_dates.date_id]
  check_time_id integer [not null, ref: > dim_times.time_id]
  coverage_start_date_id integer [not null, ref: > dim_dates.date_id]
  coverage_end_date_id integer [not null, ref: > dim_dates.date_id]
  digital_governance_system_id integer [not null, ref: > dim_digital_governance_systems.digital_governance_system_id]
  api_credentials_used_id integer [not null, ref: > dim_api_credentials.api_credentials_id]
  system_status_id integer [not null, ref: > dim_system_statuses.system_status_id]
  last_active_user_id integer [not null, ref: > dim_last_active_users.last_active_user_id]
  response_time decimal(11, 2) // 84223.23, 123.23, 32.11
  created_at timestamp [default: 'now()'] // 2026-02-12 15:18:18, 2026-02-13 15:18:18, 2026-02-14 16:18:18
  updated_at timestamp // 2026-02-12 15:18:18, 2026-02-13 15:18:18, 2026-02-14 16:18:18

  indexes {
    (coverage_start_date_id, coverage_end_date_id, system_status_id, last_active_user_id) [name: 'idx_report_lookup']
  }
}





// ============================================
// Indicator: Improvement percentage in citizen access to services
// Lead Department: PGO
// Frequency: Annually
// Data Source: Submitted Reports of PGO/POPCOM of the number of people who registered to the Bataeño Pass per Barangay
// ============================================

Table dim_barangays {
  barangay_id integer [pk, increment]
  district_name varchar(100) // District I, District II, District III
  municipality_name varchar(255) //

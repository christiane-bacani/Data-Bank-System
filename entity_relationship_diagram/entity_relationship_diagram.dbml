}

/*
Table sectors {
  sector_id integer [pk, increment]
  sector varchar(255) // Development Administration, Economic, Social
  dimension varchar(255) // Governance, Standard of Living
}
*/





// Department who will use this data: OPPDC
// Indicator: Percentage of reduction in inflation rates through price monitoring and direct selling of basic commodities
// Frequency: Annually
// Data Source: OPPDC - Development Research and Statistics Division Spreadsheet
// How to verify this data for the integrity: Check the Provincial Price Monitoring System of Development Research and Statistics Divsion from OPPDC for comparison

Table local_government_units {
  local_government_unit_id integer [pk, increment]
  local_government_unit varchar(50) // Abucay, Balanga, etc.
  district_number integer // 1, 2, 3, etc.
}

Table commodity_types {
  commodity_type_id integer [pk, increment]
  commodity_type varchar(255) // IMPORTED COMMERCIAL RICE (per kg), HIGHLAND VEGETABLES (per kg)
}

Table agricultural_products {
  agricultural_product_id integer [pk, increment] 
  commodity_type_id integer [ref: > commodity_types.commodity_type_id]
  agricultural_product varchar(255) // Cooking oil (Palm) 1L, NFA (Wellmilled)
}

Table dates {
  date_id integer [pk, increment]
  full_date date // // YYYY/MM/DD
  year year // 2025
  quarter integer // 3
  month integer // 3
  week_number integer // 54
  day_of_week day_of_week // Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, and Sunday
}

Table helpers {
  helper_id integer [pk, increment] 
  helper helper // Previous, Current, Other
}

Table prices {
  price_id integer [pk, increment]
  agricultural_product_id integer [ref: > agricultural_products.agricultural_product_id]
  local_government_unit_id integer [ref: > local_government_units.local_government_unit_id]
  observation_date_id integer [ref: > dates.date_id] 
  coverage_period_start_date integer [ref: > dates.date_id]
  coverage_period_end_date integer [ref: > dates.date_id]
  helper_id integer [ref: > helpers.helper_id]
  currency varchar(25) // PHP
  average_price decimal(11, 2) // 53.50
  prevailing_price decimal(11, 2) // 53.50
}


// Department who will use this data: OPPDC
// Indicator: % increase in barangays with completed Barangay Master Development Plans
// Frequency: Annually
// Data Source: District Office submitted by every municipality for their barangays
// How to verify this data for the integrity: It will be verified by OPPDC if the development plan passed by the municipalities per barangay is legit implemented, completed, etc.

Table municipalities {
  municipality_id integer [pk, increment]
  district varchar(25) // District 1, District 2, and District 3
  municipality_name varchar(150) // City of Balanga, Orani, Samal, Abucay
  total_barangays integer // 23, 29, 14, 9
}

Table barangays {
  barangay_id integer [pk, increment]
  municipality_id integer [ref: > municipalities.municipality_id]
  barangay_name varchar(255) // San Jose, Bilolo, Salian, Capitangan
}

Table barangay_development_plans {
  plan_id integer [pk, increment]
  date_completed_id integer [ref: > dates.date_id]
  barangay_id integer [ref: > barangays.barangay_id]
  plan_name varchar(255) // Brgy. San Jose Educational Plan
  descriptino text // San Jose establish a 
  fiscal_year YEAR // 2024
  plan_status plan_status // Not Started, Draft, In Review, Returned, and Completed
}





// Department who will use this data: Legal & PHRMO
// Indicator: % increase in citizen concerns addressed via the 8888 hotline
// Frequency: Annually
// Data Source: Annual Performance Report of 8888 Citizens' Complaint Center (8888 CCC) from Legal & PHRMO Office
// How to verify this data for the integrity: Check the Performance report for a certain period of month sent by 8888 Citizens' Complaint Center (8888 CCC)

Table ticket_classifications {
  ticket_classification_id integer [pk, increment]
  ticket_classification varchar(255) // 2024 Graft and Corruption, 2024 LGU Concerns
}

Table ticket_names {
  ticket_name_id integer [pk, increment]
  ticket_classification_id integer [ref: > ticket_classifications.ticket_classification_id]
  ticket_name varchar(255) // 2024 Against Government Official, 2024 - Agains Government Employee
}

Table ticket_summaries {
  ticket_summary_id integer [pk, increment]
  dates_id integer [ref: > dates.date_id]
  ticket_name_id integer [ref: > ticket_names.ticket_name_id]
  acted_upon bigint // 3
  under_processing bigint // 2
  unacted bigint // 4
  total_ticket bigint // 9
}


// Department who will use this data: PHRMO
// Indicator: % improvement in government employee service quality
// Frequency: Annually
// Data Source: PHRMO Outreach Program Data for Employee Participation Rate 
// How to verify this data for the integrity: Cross check the data from the PHRMO for their annual overall employee participation rate

Table service_programs {
  program_id integer [pk, increment]
  start_date_id integer [ref: > dates.date_id] // YYYY-MM-DD
  end_date_id date [ref: > dates.date_id] // YYYY-MM-DD
  program_outreach_name varchar(150)
  program_type program_type // Outreach, Training
}

Table program_heads {
  program_head_id integer [pk, increment]
  program_id integer [ref: > service_programs.program_id]
  program_head varchar(255) // Ms. Angel O.L Lara, Ar. Mc Jefferson Valerio
}

Table beneficiaries {
  beneficiary_id integer [pk, increment]
  program_id integer [ref: > service_programs.program_id]
  beneficiary_name varchar(255) // Aeta Magbukun
}

Table program_months {
  program_month_id integer [pk, increment]
  program_month_name program_month_name // January, February, March
}

Table departments {
  department_id integer [pk, increment]
  department_name varchar(100) // Office of the Provincial Planning and Development Coordinator
  department_code varchar(50) // OPPDC
  department_head varchar(150) // Ar. Mc Jefferson M. Valerio
}

Table employees {
  employee_id integer [pk, increment]
  department_id integer [ref: > departments.department_id]
  full_name varchar(255) // Christiane Rhely Joselle A. Bacani
  position varchar(100) // Data Engineer Intern
  birth_date date // YYYY-MM-DD
}

Table program_participations {
  participation_id integer [pk, increment]
  program_month_id integer [ref: > program_months.program_month_id]
  program_id integer [ref: > service_programs.program_id]
  employee_id integer [ref: > employees.employee_id]
}





// Department who will use this data: MBDA/PDRRMO/PNP
// Indicator: % reduction in crime rates through collaboration with law enforcement
// Frequency: Annually
// Data Source: PNP Crime Reports from PNP
// How to verify this data for the integrity: Cross-check the data given by the PNP to the OPPDC - Development Research and Statistics Division

Table police_stations {
  police_station_id integer [pk, increment]
  police_station varchar(255) // Balanga City Police Station 1
  barangay varchar(255) // San Jose, Munting Batangas, Tuyo
}

Table crime_datetimes {
  crime_datetime_id integer [pk, increment]
  date_commited_id integer [ref: > dates.date_id]
  time_commited time // 13:00
}

Table crime_categories {
  crime_category_id integer [pk, increment]
  crime_category crime_category // Index Crime, Other Crime/Index
}

Table stages_of_felony {
  stage_of_felony_id integer [pk, increment]
  stage_of_felony varchar(100) // Consummated, etc.
}

Table crime_offenses {
  crime_offense_id integer [pk, increment]
  crime_category_id integer [ref: > crime_categories.crime_category_id]
  stage_of_felony_id integer [ref: > stages_of_felony.stage_of_felony_id]
  crime_offense varchar(100) // Adultery, Rape, Murder
}

Table crime_incidents {
  crime_incident_id integer [pk, increment]
  police_station_id integer [ref: > police_stations.police_station_id]
  crime_datetime_id integer [ref: > crime_datetimes.crime_datetime_id]
  crime_offense_id integer [ref: > crime_offenses.crime_offense_id]
  modus varchar(255) // Caught in motel, etc.
}





// Department who will use this data: PDRRM (Place of occurence: ?), MBDA (Place of occurence: Latitude/Longitude), PNP (Place of Occurence: Barangay)
// Indicator: % reductions on accidents (place of occurrence)
// Frequency: Monthly
// Data Source:
// How to verify this data for the integrity:

Table accident_types {
  accident_type_id integer [pk, increment]
  accident_type accident_type // Vehicular, Fire, Medical
}

Table accident_severities {
  accident_severity_id integer [pk, increment]
  accident_severity accident_severity // Minor, Major, Fatal
}

Table accidents {
  accident_id integer [pk, increment]
  accident_date_id integer [ref: > dates.date_id]
  accident_types integer [ref: > accident_types.accident_type_id]
  accident_severity_id integer [ref: > accident_severities.accident_severity_id]
  city_municipality varchar(100) // Balanga City, Abucay, Orani
  barangay varchar(100) // San Jose, Bagong Silang
  location text // Front of Jollibee Bagong Silang
  latitude decimal(10, 8) // 14.681234
  longitude decimal(10, 8) // 120.534567
}


// Department who will use this data: PDRRM + MBDA, PDRRM
// Indicator: % reduction of injury among affected population during calamity, % reduction on casualty during calamity
// Frequency: During SitRep
// How to verify this data for the integrity: Check the Situational Reports of PDRRM + MBDA, PDRRM and validate it by checking the total no of injuries/casualties happen during each sitrep

// Todo: Add the population for this indicator 'reduction of injury among affected population during calamity'
Table calamities {
  calamity_id integer [pk, increment]
  calamity_name varchar(255) // Typhoon Yolanda, Earthquake with a Magnitude of 7.2
  calamity_type calamity_type // Typhoon, Tordano, Earthquake, Landslide
  description text // Typhoon Yolanda destroys multiple districts inside the Province of Bataan and Pampanga
  start_date date // YYYY/MM/DD
  end_date date // YYYY/MM/DD
}

Table reporting_units {
  reporting_unit_id integer [pk, increment]
  unit_type unit_type // Province, District, Municipality, and Barangay
  unit_name varchar(50) // Bataan, District I, District II, District III, Balanga City, Abucay, San Jose
  parent_unit_id integer
}

Table situational_reports {
  situational_report_id integer [pk, increment]
  calamity_id integer [ref: > calamities.calamity_id]
  reporting_unit_id integer [ref: > reporting_units.reporting_unit_id]
  reported_date_id integer [ref: > dates.date_id]
  situational_report_title varchar(255) // Daily Situational Report
  description text // Daily Situational Report for Common Injuries Occured During...
  report_sequence biginteger // 1, 2, 3 (The order of the situational report: reporting unit + per calamity)
}

Table casualty_types {
  casualty_type_id integer [pk, increment]
  casualty_type casualty_type
}

Table casualty_details {
  casualty_detail_id integer [pk, increment]
  situational_report_id integer [ref: > situational_reports.situational_report_id]
  casualty_type_id integer [ref: > casualty_types.casualty_type_id]
  casualty_count bigint // 43421
}

Table injury_severities {
  injury_severity_id integer [pk, increment]
  injury_severity injury_severity
}

Table injury_types {
  injury_type_id integer [pk, increment]
  injury_type injury_type // Fracture, Laceration, Burns, Contusion
}

Table injury_details {
  injury_detail_id integer [pk, increment]
  situational_report_id integer [ref: > situational_reports.situational_report_id]
  injury_severity_id integer [ref: > injury_severities.injury_severity_id]
  injury_type_id integer [ref: > injury_types.injury_type_id]
  injury_count bigint // 12343
}





// Department: Provincial Information Technology Office (PITO)
// Indicator: % increase in implementation of digital governance systems
// Frequency:
// How to verify this data for the integrity:

Table system_types {
  system_type_id integer [pk, increment]
  system_type varchar(150) // E-Government Platforms, Digital Identity and Verification, Digital Payment Systems
}

Table digital_systems {
  system_id integer [pk, increment]
  system_type integer [ref: > system_types.system_type_id]
  system_name varchar(255) // eSig, HRIS, FMIS
  description text // Explanation of the system's functions
  target_implementation_date date // YYYY-MM-DD
  is_active boolean // TRUE, FALSE
}

Table system_statuses {
  system_status_id integer [pk, increment]
  system_status system_status // Planned, Procurement, Design, Development, Testing, etc.
}

Table system_implementation_logs {
  log_id integer [pk, increment]
  system_id integer [ref: > digital_systems.system_id]
  previous_status_id integer [ref: > system_statuses.system_status_id]
  current_status_id integer [ref: > system_statuses.system_status_id]
  changed_date_id integer [ref: > dates.date_id]
  changed_by varchar(100) // Name of the person who provided this new record to update the status of the existing digital governance system
  remarks text // Deployed to Testing Server, Initial rollout to PITO employees only
}
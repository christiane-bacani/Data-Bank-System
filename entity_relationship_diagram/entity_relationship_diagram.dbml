enum day_of_week {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

enum helper {
  Previous
  Current
  Other
}

enum program_type {
  Outreach
  Training
}

enum program_month_name {
  January
  February
  March
  April
  May
  June
  July
  August
  September
  October
  November
  December  
}

enum crime_category {
  IndexCrime
  OtherCrimeSlashIndex
}

enum accident_type {
  Vehicular
  Fire
  Medical
}

enum accident_severity {
  Minor
  Major
  Fatal
}

enum calamity_type {
  Cyclone
  Typhoon
  Tornado
  Flood
  Drought
  Earthquake
  VolcanicEruption
  Landslide
  Pandemic
  IndustrialAccident
  Terrorism
}

enum unit_type {
  Province
  District
  Municipality
  Barangay
}

enum casualty_type {
  Injured
  Dead
  Missing
  ConfirmedDead
}

enum injury_severity {
  Minor
  Moderate
  Sever
  Critical
}

enum injury_type {
  Fracture
  Laceration
  Burns
  Contusion
  Sprain
  HeadTrauma
  Drowning
  Electrocution
  Hyphothermia
  Respiratory
  Other
}

enum plan_status {
  NotStarted
  Draft
  InReview
  Returned
  Completed
}

enum system_status {
  Proposed
  Rejected
  Planned
  Procurement
  Design
  Development
  Testing
  Pilot
  Deployed
  FullyImplemented
  ActiveMaintenance
  OnHold
  Discontinued

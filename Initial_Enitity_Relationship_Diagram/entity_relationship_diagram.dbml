// Indicator: Percentage of increase in barangays with completed Barangay Master Development Plans
// Lead Department: OPPDC
// Support Department: All Departments

enum classification {
  Rural
  Urban
}

enum status {
  None
  Draft
  Approved
  Completed
  Implementation
}

enum source {
  LGU
  National
  NGO
  Provate
  Mixed
}

enum type_of_analysis {
  DailyReview
  WeeklyAssessment
  MonthlyReport
  QuarterlyReview
  AnnualAssessment
}

// Barangay who wants to plan or implement a Master Development Plan
Table barangays {
  barangay_id integer [pk, increment]
  barangay_name varchar(100)
  municipality varchar(100)
  province varchar(100)
  region varchar(100)
  population bigint
  classification classification
  is_active boolean
}

// Barangay Master Development Plan
Table master_development_plans {
  plan_id integer [pk, increment]
  barangay_id integer [ref: > barangays.barangay_id]
  plan_period varchar(60)
  current_status status
  date_started date
  date_approved date
  date_completed date
  funding_source source
  budget decimal(15, 2)
  remarks text
  created_by varchar(255)
  created_date date
  updated_by varchar(255)
  updated_date date
}

// Current Reported Progress of the Master Development Plan of the certain Barangay
Table plan_progress {
  progress_id integer [pk, increment]
  plan_id integer [ref: > master_development_plans.plan_id]
  progress_date date
  completion_percentage decimal (5, 1)
  budget_utilization decimal(5, 2)
  current_challenges text
  remarks text
  reported_by varchar(100)
  reported_datetime datetime
}
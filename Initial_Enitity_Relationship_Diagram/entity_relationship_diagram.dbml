Table dim_dates {
  date_id INTEGER PK
  full_date DATE
  year YEAR
  quarter CHAR(2)
  month INTEGER
  month_name VARCHAR(20)
  week_number INTEGER
  day INTEGER
  day_of_week VARCHAR(20)
}

Table dim_barangays {
  barangay_id INTEGER PK
  barangay_name VARCHAR(100)
  city VARCHAR(50)
  province_name VARCHAR(50)
  postal_code INT(4)
  region_name VARCHAR(80)
  classification CHAR(5)
}


Table dim_development_plans {
  plan_id INTEGER PK
  development_plan_title VARCHAR(255)
  development_plan_description TEXT
  inclusive_plan_year VARCHAR(50)
  status VARCHAR(20)
  date_started DATE
  date_approved DATE
  date_completed DATE
}

Table dim_status {
  status_id INTEGER PK
  status VARCHAR(25)
  is_active BOOLEAN
  is_completed BOOLEAN
}

Table fact_plan_completions {
  id INTEGER PK
  date_id INTEGER [ref: > dim_dates.date_id]
  barangay_id INTEGER [ref: > dim_barangays.barangay_id]
  plan_id INTEGER [ref: > dim_development_plans.plan_id]
  status_id INTEGER [ref: > dim_status.status_id]
}